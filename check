#!/bin/sh
set -e

web_output=$(cd web && ./bun --silent run check 2>&1) || { echo "$web_output"; exit 1; }
./scripts/build-web.sh

go mod tidy
go install ./...
go fmt ./...
go fix -omitzero=false ./...
go vet ./...
go tool staticcheck ./...
test_output=$(go test ./... 2>&1) || { echo "$test_output"; exit 1; }
echo ok
